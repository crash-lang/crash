include ./anotherOne.cir

const content: string = "hello";

struct Message {
    content: string
}

impl Message {

    fn test() {

    }
}

impl Debugging for Message {

    fn: string to_string() {
        return this.content;
    }
}

interface Debugging {

    fn: string to_string();

}

enum struct Goofy {
    Message,
    Status
}

enum Status {
    ONLINE,
    OFFLINE,
    MAINTENANCE
}

fn: bool is_message(goofy: Goofy) {
    // one way
    if let message: Message = goofy {
        println(message.content);
        return true;
    }

    // another way of doing it
    match goofy {
        message: Message {
            println(message.content);
            return true;
        }
        status: Status {
            println(status);
            return false;
        }
    }
}

fn main() {
    let goofy: Goofy = Goofy::Message {
        content: const.content
    }

    let is_message: bool = is_message(goofy);


}